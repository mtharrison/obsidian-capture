# Copy to .env and adjust for your machine.
API_KEY="replace-me"
SENTRY_DSN=""
PORT="8080"
TZ="Europe/London"
VAULT_PATH="/absolute/path/to/your/vault"
ALEXA_SKILL_ID=""
ALEXA_VERIFY_SIGNATURE="true"
ALEXA_VERIFY_TIMESTAMP="true"
ALEXA_CAPTURE_INTENT_NAME="CaptureIntent"
ALEXA_CAPTURE_SLOT_NAME="captureText"
DAILY_NOTE_PATH_TEMPLATE="Bullet Journal/Daily/{{YYYY}}-{{MM}}-{{DD}} ({{DAY_NAME}} W{{ISO_WEEK}}).md"
DAILY_NOTE_TITLE_TEMPLATE="# {{YYYY}}-{{MM}}-{{DD}}"
CAPTURE_SECTION_HEADING="Captured"
CONFIG_PATH="/data/config"
